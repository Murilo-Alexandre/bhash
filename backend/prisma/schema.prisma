generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageContentType {
  TEXT
  IMAGE
  FILE
  AUDIO
}

enum ConversationKind {
  DIRECT
  GROUP
  BROADCAST
}

enum MediaRetentionInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users                   User[]
  conversationBroadcasts  ConversationBroadcastCompany[]

  @@map("companies")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users                   User[]
  conversationBroadcasts  ConversationBroadcastDepartment[]

  @@map("departments")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  name               String

  email              String?
  extension          String?
  avatarUrl          String?

  passwordHash       String
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  lastLoginAt        DateTime?

  companyId          String?
  departmentId       String?

  company            Company?    @relation(fields: [companyId], references: [id])
  department         Department? @relation(fields: [departmentId], references: [id])

  conversationsA     Conversation[]   @relation("ConversationUserA")
  conversationsB     Conversation[]   @relation("ConversationUserB")
  createdConversations Conversation[] @relation("ConversationCreator")
  conversationParticipants ConversationParticipant[] @relation("ConversationParticipantUser")
  broadcastTargets   ConversationBroadcastTarget[] @relation("ConversationBroadcastTargetUser")
  broadcastExcludedFrom ConversationBroadcastExcludedUser[] @relation("ConversationBroadcastExcludedUser")
  sentMessages       Message[]        @relation("MessageSender")
  conversationStates ConversationUserState[]
  messageVisibility  MessageVisibility[]
  favoriteMessages   MessageFavorite[]
  reactions          MessageReaction[]

  @@index([companyId])
  @@index([departmentId])

  @@map("users")
}

model AdminAccount {
  id                    String   @id @default(uuid())
  username              String   @unique
  name                  String
  passwordHash          String
  isActive              Boolean  @default(true)
  isSuperAdmin          Boolean  @default(false)
  mustChangeCredentials Boolean  @default(false)
  mustChangePassword    Boolean  @default(false)
  createdAt             DateTime @default(now())
  lastLoginAt           DateTime?

  @@map("admin_accounts")
}

model AppConfig {
  id                      String                 @id
  primaryColor            String                 @default("#001F3F")
  primaryTextColor        String                 @default("#F0F0F0")
  logoUrl                 String?
  mediaRetentionEnabled   Boolean                @default(false)
  mediaRetentionInterval  MediaRetentionInterval @default(MONTHLY)
  mediaRetentionIntervalCount Int                @default(1)
  mediaRetentionRunHour   Int                    @default(0)
  mediaRetentionRunMinute Int                    @default(0)
  mediaRetentionShowToUsers Boolean              @default(false)
  mediaRetentionNextRunAt DateTime?
  mediaRetentionLastRunAt DateTime?
  mediaRetentionLastMediaCount Int               @default(0)
  mediaRetentionLastFileCount Int                @default(0)
  mediaRetentionLastSummary String?

  @@map("app_config")
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kind        ConversationKind @default(DIRECT)
  title       String?
  avatarUrl   String?
  createdById String?
  userAId     String?
  userBId     String?
  broadcastIncludeAllUsers Boolean @default(false)

  createdBy User? @relation("ConversationCreator", fields: [createdById], references: [id])
  userA     User? @relation("ConversationUserA", fields: [userAId], references: [id])
  userB     User? @relation("ConversationUserB", fields: [userBId], references: [id])

  participants     ConversationParticipant[]
  broadcastTargets ConversationBroadcastTarget[]
  broadcastCompanyTargets ConversationBroadcastCompany[]
  broadcastDepartmentTargets ConversationBroadcastDepartment[]
  broadcastExcludedUsers ConversationBroadcastExcludedUser[]
  broadcastMessages Message[] @relation("MessageBroadcastSource")
  messages         Message[]
  states           ConversationUserState[]

  @@unique([userAId, userBId])
  @@index([kind])
  @@index([createdById])
  @@index([updatedAt])
  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  addedById      String?
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationParticipantUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_participants")
}

model ConversationBroadcastTarget {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationBroadcastTargetUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_broadcast_targets")
}

model ConversationBroadcastCompany {
  id             String   @id @default(uuid())
  conversationId String
  companyId      String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  company      Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([conversationId, companyId])
  @@index([companyId])
  @@map("conversation_broadcast_companies")
}

model ConversationBroadcastDepartment {
  id             String   @id @default(uuid())
  conversationId String
  departmentId   String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([conversationId, departmentId])
  @@index([departmentId])
  @@map("conversation_broadcast_departments")
}

model ConversationBroadcastExcludedUser {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation("ConversationBroadcastExcludedUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@map("conversation_broadcast_excluded_users")
}

model Message {
  id             String             @id @default(uuid())
  createdAt      DateTime           @default(now())

  conversationId String
  senderId       String

  body           String?
  contentType    MessageContentType @default(TEXT)

  attachmentUrl  String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?

  replyToId      String?
  deletedAt      DateTime?
  broadcastListId String?
  broadcastListTitle String?

  conversation   Conversation       @relation(fields: [conversationId], references: [id])
  sender         User               @relation("MessageSender", fields: [senderId], references: [id])
  broadcastList  Conversation?      @relation("MessageBroadcastSource", fields: [broadcastListId], references: [id])

  replyTo        Message?           @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]          @relation("MessageReply")

  favorites      MessageFavorite[]
  reactions      MessageReaction[]
  hiddenForUsers MessageVisibility[]

  @@index([conversationId, createdAt])
  @@index([broadcastListId])
  @@index([replyToId])
  @@index([senderId])
  @@map("messages")
}

model ConversationUserState {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  hidden         Boolean  @default(false)
  pinned         Boolean  @default(false)
  clearedAt      DateTime?
  lastReadAt     DateTime?
  leftAt         DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, hidden])
  @@index([userId, pinned])
  @@index([userId, leftAt])
  @@map("conversation_user_states")
}

model MessageVisibility {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  hiddenAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, hiddenAt])
  @@map("message_visibility")
}

model MessageFavorite {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_favorites")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reactions")
}
